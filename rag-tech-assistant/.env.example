# Copy this file to .env and fill in your own values.
# Never commit the actual .env file — it's already in .gitignore.

# Required: used for chat completions (query analysis, grading, generation)
# and for text-embedding-3-small in the ingestion pipeline.
OPENAI_API_KEY=sk-your-key-here

# Optional: only needed if you implement the web-search-fallback bonus feature.
# TAVILY_API_KEY=tvly-your-key-here

# Optional: LangSmith tracing, useful for debugging the graph's retry loops.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=ls-your-key-here
# LANGSMITH_PROJECT=rag-tech-assistant
